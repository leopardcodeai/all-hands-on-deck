{
  "rules": {
    "sessions": {
      "$sessionId": {
        ".read": "$sessionId.matches(/^[A-Z0-9]{6,16}$/)",
        ".write": "$sessionId.matches(/^[A-Z0-9]{6,16}$/)",

        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['sessionId','senderId','createdAt','event']) && newData.child('sessionId').isString() && newData.child('senderId').isString() && newData.child('senderId').val().length <= 64 && newData.child('createdAt').isString() && newData.child('createdAt').val().length <= 32",
            "event": { ".validate": "newData.val() != null" },
            "$other": { ".validate": false }
          }
        },

        "currentFrame": {
          ".validate": "newData.hasChildren(['sessionId','senderId','createdAt','event'])",
          "$other": { ".validate": true }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
